{
  "hosting":[
    {
      "target": "arcl",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "/go.html", "destination": "/go.html" },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "geetabitan",
      "public": "dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]

}
